# ─────────────────────────────────────────────────────────────────────────────
# EatMe Mobile App — Environment Variables (Expo / React Native)
# Copy this file to .env and fill in the values.
# .env is gitignored and must NEVER be committed.
#
# All variables must be prefixed with EXPO_PUBLIC_ to be accessible in the
# JavaScript bundle. Variables without this prefix are server-only and are
# NOT available in the React Native runtime.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google Sign-In ───────────────────────────────────────────────────────────
# Required for native one-tap Google authentication (no password prompt).
# This is the Web OAuth Client ID from Google Cloud Console.
# Path: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web client
# IMPORTANT: This must be the *Web* client ID (ends in .apps.googleusercontent.com),
# NOT the Android or iOS client ID. The native SDKs use this to verify the ID token.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ── Mapbox ───────────────────────────────────────────────────────────────────
# Required for the map screen. Token must start with "pk." (public token).
# Create a token at: https://account.mapbox.com/access-tokens/
# See also: apps/mobile/MAPBOX_RESTORATION.md for full setup guide.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token-here

# ── API / Edge Functions ──────────────────────────────────────────────────────
# Base URL for Supabase Edge Functions.
# Format: https://your-project-ref.supabase.co/functions/v1
EXPO_PUBLIC_API_URL=https://your-project-ref.supabase.co/functions/v1

# ── Map defaults ─────────────────────────────────────────────────────────────
# Initial map centre shown before the user grants location permission.
# These are used as fallback coordinates only.
EXPO_PUBLIC_DEFAULT_LAT=19.4326
EXPO_PUBLIC_DEFAULT_LNG=-99.1332
EXPO_PUBLIC_DEFAULT_ZOOM=12

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to "true" to enable verbose debugLog output in development builds.
# Should be "false" (or omitted) in production / EAS builds.
EXPO_PUBLIC_DEBUG=true
EXPO_PUBLIC_DEFAULT_ZOOM=12